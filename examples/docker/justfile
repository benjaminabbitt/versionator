# Docker example - builds a container image with embedded version info
# This example differs from others: it produces a deployable container image
# rather than running builds inside a container

VERSIONATOR := "../../bin/versionator"
IMAGE_NAME := "sample-app"
REPO_ROOT := `git rev-parse --show-toplevel`

# Default: build and run
default: run

# ============================================================================
# Docker image build (embeds version into the image)
# ============================================================================

# Build Docker image with version info embedded
docker-build:
    #!/bin/bash
    set -e
    VERSION=$({{VERSIONATOR}} version 2>/dev/null || echo "dev")
    COMMIT=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
    DATE=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    echo "Building Docker image with:"
    echo "  VERSION=$VERSION"
    echo "  GIT_COMMIT=$COMMIT"
    echo "  BUILD_DATE=$DATE"
    podman build \
        --build-arg VERSION="$VERSION" \
        --build-arg GIT_COMMIT="$COMMIT" \
        --build-arg BUILD_DATE="$DATE" \
        -t {{IMAGE_NAME}}:$VERSION \
        -t {{IMAGE_NAME}}:latest \
        .

# Run the Docker container
docker-run:
    #!/bin/bash
    VERSION=$({{VERSIONATOR}} version 2>/dev/null || echo "latest")
    echo "Running {{IMAGE_NAME}}:$VERSION"
    podman run --rm {{IMAGE_NAME}}:$VERSION

# Build and run
run: docker-build docker-run

# Inspect image labels to verify embedded version info
docker-inspect:
    #!/bin/bash
    VERSION=$({{VERSIONATOR}} version 2>/dev/null || echo "latest")
    echo "Inspecting labels for {{IMAGE_NAME}}:$VERSION"
    podman inspect {{IMAGE_NAME}}:$VERSION --format=json | python3 -c "import sys,json; labels=json.load(sys.stdin)[0]['Config']['Labels']; print(json.dumps(labels, indent=2))"

# Show version info that would be embedded
show-version:
    #!/bin/bash
    VERSION=$({{VERSIONATOR}} version 2>/dev/null || echo "NOT SET")
    COMMIT=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
    DATE=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    echo "Version from versionator:"
    echo "  VERSION=$VERSION"
    echo "  GIT_COMMIT=$COMMIT"
    echo "  BUILD_DATE=$DATE"

# Clean up images
clean:
    #!/bin/bash
    VERSION=$({{VERSIONATOR}} version 2>/dev/null || echo "latest")
    podman rmi {{IMAGE_NAME}}:$VERSION {{IMAGE_NAME}}:latest 2>/dev/null || true
