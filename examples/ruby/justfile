# Ruby example with container support
# Uses overlay pattern: justfile.container is mounted over justfile inside container

VERSIONATOR := "../../bin/versionator"
IMAGE_NAME := "versionator-example-ruby"
REPO_ROOT := `git rev-parse --show-toplevel`

# Default: run locally
default: run

# ============================================================================
# Local execution (uses local versionator binary)
# ============================================================================

# Generate version.rb from versionator
version-file:
    #!/bin/bash
    set -e
    echo "Generating version.rb using versionator emit..."
    {{VERSIONATOR}} emit ruby --output lib/mypackage/version.rb

# Build the gem (generates version.rb first)
build: version-file
    #!/bin/bash
    set -e
    echo "Building Ruby gem..."
    gem build mypackage.gemspec
    echo "Build completed!"

# Install the gem locally
install: build
    gem install mypackage-*.gem

# Run the sample application
run: version-file
    ruby bin/mypackage

# Clean build artifacts
clean:
    rm -f lib/mypackage/version.rb
    rm -f *.gem

# Show the version that would be used
show-version:
    #!/bin/bash
    VERSION=$({{VERSIONATOR}} version 2>/dev/null || echo "NOT SET")
    echo "Version from versionator: $VERSION"

# Run tests
test: version-file
    bundle exec rspec 2>/dev/null || echo "No tests found or rspec not installed"

# Generate using custom template file
version-file-template:
    #!/bin/bash
    set -e
    echo "Generating version.rb using template file..."
    {{VERSIONATOR}} emit --template-file lib/mypackage/version.rb.tmpl --output lib/mypackage/version.rb

# ============================================================================
# Container execution (overlay pattern)
# ============================================================================

# Build the container image
container-build:
    podman build -t {{IMAGE_NAME}} -f Containerfile .

# Run command inside container (internal helper)
_container-run +ARGS:
    podman run --rm \
        -v {{REPO_ROOT}}/VERSION:/workspace/VERSION:ro \
        -v {{justfile_directory()}}/justfile.container:/workspace/justfile:ro \
        -v {{justfile_directory()}}/lib:/workspace/lib:rw \
        -v {{justfile_directory()}}/mypackage.gemspec:/workspace/mypackage.gemspec:ro \
        -w /workspace \
        {{IMAGE_NAME}} just {{ARGS}}

# Build inside container
container-run: container-build
    just _container-run run

# Clean inside container
container-clean: container-build
    just _container-run clean

# Show version inside container
container-show-version: container-build
    just _container-run show-version
