# Python example with container support
# Uses overlay pattern: justfile.container is mounted over justfile inside container

VERSIONATOR := "../../bin/versionator"
IMAGE_NAME := "versionator-example-python"
REPO_ROOT := `git rev-parse --show-toplevel`

# Default: run locally
default: run

# ============================================================================
# Local execution (uses local versionator binary)
# ============================================================================

# Generate _version.py from versionator
version-file:
    #!/bin/bash
    set -e
    echo "Generating _version.py using versionator emit..."
    {{VERSIONATOR}} emit python --output mypackage/_version.py

# Build the package (generates _version.py first)
build: version-file
    #!/bin/bash
    set -e
    echo "Building Python package..."
    python -m build
    echo "Build completed: dist/"

# Install in development mode
install: version-file
    pip install -e .

# Run the sample application
run: version-file
    python -m mypackage.main

# Run using environment variable (no file generation)
env-run:
    #!/bin/bash
    echo "Running with version from environment variable..."
    APP_VERSION=$({{VERSIONATOR}} version) python -c "
    import os
    print('Sample Python Application')
    print(f'Version: {os.environ.get(\"APP_VERSION\", \"unknown\")}')
    "

# Clean build artifacts
clean:
    rm -rf build/ dist/ *.egg-info/
    rm -f mypackage/_version.py
    find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true

# Show the version that would be used
show-version:
    #!/bin/bash
    VERSION=$({{VERSIONATOR}} version 2>/dev/null || echo "NOT SET")
    echo "Version from versionator: $VERSION"

# Generate using custom template file
version-file-template:
    #!/bin/bash
    set -e
    echo "Generating _version.py using template file..."
    {{VERSIONATOR}} emit --template-file mypackage/_version.py.tmpl --output mypackage/_version.py

# ============================================================================
# Container execution (overlay pattern)
# ============================================================================

# Build the container image
container-build:
    podman build -t {{IMAGE_NAME}} -f Containerfile .

# Run command inside container (internal helper)
_container-run +ARGS:
    podman run --rm \
        -v {{REPO_ROOT}}/VERSION:/workspace/VERSION:ro \
        -v {{justfile_directory()}}/justfile.container:/workspace/justfile:ro \
        -v {{justfile_directory()}}/mypackage:/workspace/mypackage:rw \
        -v {{justfile_directory()}}/pyproject.toml:/workspace/pyproject.toml:ro \
        -w /workspace \
        {{IMAGE_NAME}} just {{ARGS}}

# Build inside container
container-run: container-build
    just _container-run run

# Clean inside container
container-clean: container-build
    just _container-run clean

# Show version inside container
container-show-version: container-build
    just _container-run show-version
