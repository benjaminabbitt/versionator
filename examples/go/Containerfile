# Go development container with versionator
# Uses multi-stage build to copy versionator from official image

FROM ghcr.io/benjaminabbitt/versionator:latest AS versionator

FROM docker.io/library/golang:1.21-alpine

# Install make and dependencies
RUN apk add --no-cache bash git make

# Copy versionator from official image
COPY --from=versionator /versionator /usr/local/bin/versionator

WORKDIR /workspace

# Default command
CMD ["make", "run"]
