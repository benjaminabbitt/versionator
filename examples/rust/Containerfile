# Rust development container with versionator

FROM ghcr.io/benjaminabbitt/versionator:latest AS versionator

FROM docker.io/library/rust:1.75-alpine

# Install make and dependencies
RUN apk add --no-cache bash git make musl-dev

# Copy versionator from official image
COPY --from=versionator /versionator /usr/local/bin/versionator

WORKDIR /workspace

CMD ["make", "run"]
