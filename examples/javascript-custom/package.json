{
  "name": "mypackage-custom",
  "version": "0.0.0",
  "description": "Sample package demonstrating versionator custom template integration",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "version": "../../bin/versionator emit --template-file src/version.tmpl.js --output src/version.js",
    "prestart": "npm run version",
    "start": "node src/index.js",
    "clean": "rm -f src/version.js"
  },
  "keywords": ["versionator", "example", "custom-template"],
  "license": "MIT"
}
